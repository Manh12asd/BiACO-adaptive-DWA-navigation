<?xml version="1.0"?>


<robot name="pibot" xmlns:xacro="http://ros.org/wiki/xacro">
    
    <xacro:include filename="$(find pibot_description)/urdf/pibot_gazebo.xacro" />
    <xacro:include filename="$(find pibot_description)/urdf/pibot_ros2control.xacro" />

    <link name="base_footprint"/>
    
    <link name="base_link">
        <inertial>
        <origin xyz="0 0 0.07" rpy="0.0 0.25 0.3" />
        <mass value="8.2573504e-01"/>
        <inertia ixx="2.2124416e-02" ixy="-1.2294101e-04" ixz="3.4938785e-04"
                iyy="2.1193702e-02" iyz="-5.0120904e-05"
                izz="2.0064271e-02" />
        </inertial>
        
        <visual>
        <origin xyz="0 0 0.07" rpy="0 0 0" />
        <geometry>
            <box size="0.135 0.135 0.14" />
        </geometry>
        <material name="red"/>
        </visual>
        
        <collision>
        <origin xyz="0 0 0.07" rpy="0 0 0" />
        <geometry>
            <box size="0.135 0.135 0.14" />
        </geometry>
        </collision>
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link" />
        <origin xyz="0 0 0.033" rpy="0 0 0"/>
    </joint>

    
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>
    <material name="silver">
        <color rgba="0.79 0.82 0.93 1"/>
    </material>
    <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
    </material>

    <link name="wheel_left_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder radius="0.0335" length="0.025"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder radius="0.0335" length="0.025"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0.014 0" rpy="0 0 0" />
            <mass value="0.0530086043217644" />
            <inertia ixx="1.8792911368909E-05"  ixy="3.31256392204584E-10" ixz="-1.14082001662767E-08"
                    iyy="3.11510738759073E-05" iyz="-3.60499245082192E-10"
                    izz="1.88266886146847E-05" />
        </inertial>
    </link>

    <joint name="wheel_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_left_link"/>
        <origin xyz="-0.0355 0.08675 0.01839" rpy="0 0 0" />
        <axis xyz="0 1 0"/>
    </joint>

    <link name="wheel_right_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder radius="0.0335" length="0.025"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder radius="0.0335" length="0.025"/>
        </geometry>
        </collision>
        <inertial>
            <origin xyz="0 -0.014 0" rpy="0 0 0" />
            <mass value="0.0530086090966721" />
            <inertia ixx="1.88176298336665E-05" ixy="-4.8444933029987E-10" ixz="1.88163708851143E-08"
                    iyy="3.11510738647764E-05" iyz="-6.93560663069607E-11"
                    izz="1.8801969558182E-05" />
        </inertial>
    </link>

    <joint name="wheel_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_right_link"/>
        <origin xyz="-0.0355 -0.08675 0.01839" rpy="0 0 0" />
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser_link"/>
        <origin xyz="0 0 0.1526" rpy="0 0 0"/>
    </joint>

    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.035" length="0.05"/>
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.035" length="0.05"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.17"/> 
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                    iyy="0.0001" iyz="0.0"
                    izz="0.0001"/>
        </inertial>
    </link>

    <link name="caster_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
            <material name="silver"/>
        </visual>
        
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.0151"/>
            </geometry>
        </collision>
        
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.05"/>
            <inertia ixx="4.5e-06" ixy="0.0" ixz="0.0" 
                    iyy="4.5e-06" iyz="0.0" 
                    izz="4.5e-06"/>
        </inertial>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>
        <origin xyz="0.05 0 0" rpy="0 0 0"/>
    </joint>

    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.01 0.01 0.005"/>
            </geometry>
            <material name="black"/>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0225 0 0" rpy="0 0 0"/>
    </joint>

</robot>